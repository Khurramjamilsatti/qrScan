# Copy to backend/.env.docker for docker-compose.prod.yml
# DB_PASSWORD must match the value in project root .env (see .env.docker-compose.example)
# Generate APP_KEY: docker compose -f docker-compose.prod.yml run --rm api php artisan key:generate --show

APP_NAME=QRScan
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
CNAME_TARGET=app.qrscan.digital

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=qrscan
DB_USERNAME=qrscan
DB_PASSWORD=change-me-in-production

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=localhost

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=public

MAIL_MAILER=log

HUGGINGFACE_API_TOKEN=
HUGGINGFACE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_DISABLE_PROXY=true
STRIPE_DISABLE_HTTP2=true
